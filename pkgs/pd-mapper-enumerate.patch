+static int pd_enumerate_jsons_from_env(struct assoc *json_set)
+{
+	char *env_val, *paths, *path_tok, *saveptr;
+	char firmware_base[PATH_MAX];
+	char dir_path[PATH_MAX];
+	char json_path[PATH_MAX];
+	struct dirent *fw_de;
+	DIR *fw_dir;
+	size_t len;
+	int n;
+
+	env_val = getenv("PD_MAPPER_FIRMWARE_PATH");
+	if (!env_val || !*env_val)
+		return -1;
+
+	/* Read firmware base from sysfs, fall back to /lib/firmware/ */
+	int fw_param_fd = open(FIRMWARE_PARAM_PATH, O_RDONLY);
+	if (fw_param_fd >= 0) {
+		n = read(fw_param_fd, firmware_base, sizeof(firmware_base) - 1);
+		close(fw_param_fd);
+		if (n > 1) {
+			firmware_base[n - 1] = '\0';
+		} else {
+			strcpy(firmware_base, FIRMWARE_BASE);
+		}
+	} else {
+		strcpy(firmware_base, FIRMWARE_BASE);
+	}
+
+	paths = strdup(env_val);
+	if (!paths)
+		return -1;
+
+	for (path_tok = strtok_r(paths, ":", &saveptr); path_tok;
+	     path_tok = strtok_r(NULL, ":", &saveptr)) {
+
+		snprintf(dir_path, sizeof(dir_path), "%s/%s", firmware_base, path_tok);
+
+		fw_dir = opendir(dir_path);
+		if (!fw_dir)
+			continue;
+
+		while ((fw_de = readdir(fw_dir)) != NULL) {
+			int extens_index;
+
+			if (fw_de->d_name[0] == '.')
+				continue;
+
+			len = strlen(fw_de->d_name);
+			for (extens_index = 0; known_extensions[extens_index]; extens_index++) {
+				int extens_len = strlen(known_extensions[extens_index]);
+				if (len > (size_t)extens_len &&
+				    !strcmp(&fw_de->d_name[len - extens_len], known_extensions[extens_index])) {
+					snprintf(json_path, sizeof(json_path), "%s/%s", dir_path, fw_de->d_name);
+					assoc_set(json_set, json_path, NULL);
+					break;
+				}
+			}
+		}
+		closedir(fw_dir);
+	}
+
+	free(paths);
+	return 0;
+}
